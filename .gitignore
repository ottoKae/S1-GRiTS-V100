# Python bytecode
__pycache__/
*.pyc
*.pyo
*$py.class

# Compiled Cython extensions (platform-specific binaries)
# Note: pre-compiled .pyd and .so files for distribution are tracked
*.dll
# Allow compiled extension binaries in the package directory
!src/s1grits/*.so

# Build artifacts
build/
dist/
*.egg-info/
.eggs/
wheels/
*.whl

# C files generated by Cython
*.c
*.cpp

# Distribution / packaging
.Python
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Conda
.conda/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
*.cover

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Ruff cache
.ruff_cache/

# IDE settings
.vscode/
.idea/
*.swp
*.swo
*~

# OS-specific
.DS_Store
Thumbs.db
desktop.ini

# S1-GRiTS output data (never commit large datasets)
output*/
output_*/
logs/
*.log
*.tif
*.zarr/
# Exclude parquet output files, but NOT the bundled LUT data in src/
*.parquet
!src/s1grits/data/*.parquet

# ASF credentials (never commit)
.netrc
.asf_auth
*.credential

# Files
docs/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.bak2
